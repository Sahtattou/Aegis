NEO4J_URI=bolt://neo4j:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=replace_with_strong_neo4j_password
NEO4J_CONNECTION_TIMEOUT_SECONDS=1
NEO4J_ACQUISITION_TIMEOUT_SECONDS=1
NEO4J_PLUGINS=["apoc"]
NEO4J_INIT_ON_STARTUP=true
NEO4J_INIT_DIR=/app/neo4j/init

CLAUDE_API_KEY=your_claude_api_key
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_TIMEOUT_SECONDS=6
OPENAI_MAX_RETRIES=0
REDTEAM_VECTOR_INDEX_NAME=attack_embedding_index
REDTEAM_VECTOR_DIMENSIONS=384

EMBEDDING_MODEL_NAME=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
EMBEDDING_DEVICE=cpu
EMBEDDING_CACHE_DIR=data/models/cache
EMBEDDING_FALLBACK_DIM=384

CLASSIFIER_MODEL_ROOT=data/models/blueteam/classifier
CLASSIFIER_ACTIVE_VERSION=latest

ALLOWED_ORIGINS=["http://localhost:5173"]
TRUSTED_HOSTS=["localhost","127.0.0.1","gateway"]
INTERNAL_API_KEY=replace_with_secure_internal_key_min_32_chars

API_HOST=0.0.0.0
API_PORT=8000
GATEWAY_PORT=8000
REDTEAM_PORT=8001
BLUETEAM_PORT=8002
BLINDSPOT_PORT=8003
AUDIT_PORT=8004

REDTEAM_URL=http://redteam:8001
BLUETEAM_URL=http://blueteam:8002
BLINDSPOT_URL=http://blindspot:8003
AUDIT_URL=http://audit:8004

FRONTEND_PORT=5173
